# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=MTQ4MTA3Mzg4MTUwNTcyNjUxNA.GhjoBW.T9yzCh0xzA6za50UEWa8SUngyi4b6jwCJLF8D0

# The specific Discord channel ID to read macro stats from
DISCORD_CHANNEL_ID=1300318687386931241

# How many messages to fetch from that channel on startup
DISCORD_HISTORY_LIMIT=50

# Screenshot interval in seconds
SCREENSHOT_INTERVAL=3

# WebSocket heartbeat interval in seconds
WS_HEARTBEAT=5

# Bind host/port for the FastAPI server
HOST=0.0.0.0
PORT=8000

# Cloudflared tunnel name (must match config.yml)
TUNNEL_NAME=pc-dashboard

# Optional: RDP window title substring to find & capture
RDP_WINDOW_TITLE=Remote Desktop
